{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://api.total-hunter.com/$1" },
    { "source": "/img/(.*)", "destination": "/img/$1" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
